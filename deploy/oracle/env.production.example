# /opt/onbidapp/.env — 서버에만 두고 git에 올리지 마세요.
NODE_ENV=production
PORT=3000

# 공공데이터포털 온비드 인코딩 인증키 (서버 전용, 앱에 넣지 않음)
ONBID_SERVICE_KEY=여기에_인코딩된_서비스키

# 회원가입 환영 메일 (선택)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=앱비밀번호
# MAIL_FROM=your@gmail.com
# MAIL_FROM_NAME=에드가공매
