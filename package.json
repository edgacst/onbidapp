{
  "name": "onbid-auction-app",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:phone": "node scripts/dev-phone.mjs",
    "phone": "node scripts/phone-connect.mjs",
    "phone:wifi": "node scripts/phone-wifi.mjs",
    "phone:firewall": "powershell -ExecutionPolicy Bypass -File scripts/phone-firewall.ps1",
    "phone:setup": "node scripts/phone-setup.mjs",
    "phone:dev": "node scripts/dev-phone.mjs",
    "phone:prod": "node scripts/phone-launch.mjs --port 3000 --server prod --keep-alive",
    "build": "node scripts/build.mjs",
    "build:phone": "node scripts/build-phone.mjs",
    "build:inner": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node scripts/start-server.mjs --foreground",
    "restart": "node scripts/restart-server.mjs",
    "stop": "node scripts/stop-server.mjs",
    "prod": "node scripts/build.mjs && node server/index.js",
    "refresh": "node scripts/build.mjs && node scripts/ensure-build.mjs",
    "start:phone": "node scripts/build.mjs && node scripts/phone-launch.mjs --port 3000 --server prod --keep-alive"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.1.1",
    "express": "^4.22.2",
    "http-proxy-middleware": "^3.0.7",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "7.3.5"
  }
}
